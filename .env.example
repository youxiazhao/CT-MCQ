# ── Required ─────────────────────────────────────────────────────────────────
# OpenAI API key with access to the Responses API (gpt-5.4 / gpt-5.4-mini / gpt-5.4-nano).
OPENAI_API_KEY=sk-...

# ── Optional — Langfuse LLM tracing ──────────────────────────────────────────
# If both keys are set, the pipeline enables Langfuse span tracing automatically.
# Leave empty or remove to disable tracing.
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com
